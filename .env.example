# Copy to .env on the server. Never commit real credentials or resolved secrets.
LHMSB_DATA_ROOT=/data/lhmsb
LHMSB_REPO_ROOT=.
LHMSB_ENV_FILE=/data/lhmsb/env/operator.env
LHMSB_EMBEDDING_GPU_ID=0
LHMSB_RERANKER_GPU_ID=1
LHMSB_LIVE_PREFLIGHT=0
LHMSB_LIVE_QUALIFICATION=0

# Native runtime binaries and model directories installed on the host.
LHMSB_QDRANT_BIN=/opt/qdrant/qdrant
LHMSB_NEO4J_HOME=/opt/neo4j
LHMSB_JAVA_HOME=/usr/lib/jvm/temurin-17-jdk
LHMSB_TEI_BIN=/opt/tei/text-embeddings-router
LHMSB_EMBEDDING_MODEL_DIR=/data/lhmsb/models/bge-m3
LHMSB_RERANKER_MODEL_DIR=/data/lhmsb/models/bge-reranker-v2-m3
LHMSB_NEO4J_PASSWORD=
LHMSB_RUNTIME_MANIFEST_PATH=/data/lhmsb/manifests/native-runtime.json
LHMSB_MODEL_BUNDLE_MANIFEST_PATH=/data/lhmsb/manifests/model-bundle.json

# Native services bind to loopback. Ports are allocated per run when omitted.
LHMSB_QDRANT_URL=http://127.0.0.1:6333
LHMSB_EMBEDDING_URL=http://127.0.0.1:8080
LHMSB_RERANKER_URL=http://127.0.0.1:8081
LHMSB_NEO4J_URI=bolt://127.0.0.1:7687

# Controlled-Zen provider routes. Keep keys only in the operator env file.
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
