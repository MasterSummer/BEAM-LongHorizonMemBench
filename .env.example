# Copy to .env on the server. Never commit real credentials or resolved secrets.
LHMSB_DATA_ROOT=/data/lhmsb
LHMSB_WORKER_UID=
LHMSB_WORKER_GID=
LHMSB_EMBEDDING_GPU_ID=0
LHMSB_RERANKER_GPU_ID=1
LHMSB_LIVE_PREFLIGHT=0
LHMSB_LIVE_QUALIFICATION=0

# Immutable OCI references. Bootstrap resolves tags to real sha256 digests.
PYTHON_BASE_IMAGE=python:3.11-slim
PYTHON_BASE_DIGEST=
QDRANT_IMAGE=qdrant/qdrant
QDRANT_IMAGE_TAG=v1.15.4
QDRANT_IMAGE_DIGEST=
QDRANT_RUNTIME_IMAGE_ID=
TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference
TEI_IMAGE_TAG=1.8.0
TEI_IMAGE_DIGEST=
TEI_RUNTIME_IMAGE_ID=
LHMSB_WORKER_IMAGE=lhmsb-mem0-worker
LHMSB_WORKER_IMAGE_DIGEST=

# Internal service identities are fixed by the Compose network.
LHMSB_QDRANT_URL=http://qdrant:6333
LHMSB_EMBEDDING_URL=http://embedding:80
LHMSB_RERANKER_URL=http://reranker:80

# Current Controlled-Zen provider controls.
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
